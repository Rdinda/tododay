// TodoDay - Prisma Schema
// Stack: Next.js + Prisma + SQLite

generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────
// Domínio (SQLite não suporta enum nativo)
// Os valores válidos são validados na aplicação
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  passcodeHash  String
  name          String?
  timezone      String   @default("America/Sao_Paulo")
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  createdAt     DateTime @default(now())

  days Day[]
}

// DayStatus: "OPEN" | "IN_PROGRESS" | "DONE" | "FAILED"
model Day {
  id            String    @id @default(cuid())
  userId        String
  date          String    // formato ISO: "YYYY-MM-DD"
  status        String    @default("OPEN")
  note          String?
  streakAtClose Int?
  createdAt     DateTime  @default(now())
  closedAt      DateTime?

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks    Task[]
  sessions PomodoroSession[]

  // Um registro por usuário por dia
  @@unique([userId, date])
}

// TaskPriority: "HIGH" | "LOW"
// TaskStatus: "PENDING" | "IN_PROGRESS" | "DONE" | "SKIPPED"
model Task {
  id        String   @id @default(cuid())
  dayId     String
  title     String
  priority  String   @default("HIGH")
  status    String   @default("PENDING")
  order     Int
  createdAt DateTime @default(now())

  day      Day               @relation(fields: [dayId], references: [id], onDelete: Cascade)
  sessions PomodoroSession[]
}

model PomodoroSession {
  id          String    @id @default(cuid())
  dayId       String
  taskId      String?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationMin Int       @default(25)
  completed   Boolean   @default(false)

  day  Day   @relation(fields: [dayId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)
}